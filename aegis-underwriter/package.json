{
  "name": "aegis-underwriter",
  "version": "1.0.0",
  "description": "Autonomous AI lending agent for Tether Hackathon Galactica",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "server": "ts-node src/server.ts",
    "compile": "hardhat compile",
    "deploy:amoy": "hardhat run scripts/deploy.ts --network polygonAmoy",
    "deploy:sepolia": "hardhat run scripts/deploy.ts --network baseSepolia",
    "deploy:usdt": "hardhat run scripts/deployMockUSDT.ts --network polygonAmoy",
    "mint": "hardhat run scripts/mintMockUSDT.ts --network polygonAmoy",
    "test": "hardhat test",
    "clean": "hardhat clean",
    "credit": "ts-node src/testCredit.ts",
    "heartbeat": "ts-node src/heartbeat.ts"
  },
  "keywords": [
    "tether",
    "wdk",
    "defi",
    "lending",
    "ai-agent"
  ],
  "author": "Aegis Team",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/inquirer": "^9.0.9",
    "@types/node": "^20.11.0",
    "hardhat": "^2.19.4",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.1",
    "@tetherto/wdk": "latest",
    "chalk": "^4.1.2",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "express": "^5.2.1",
    "inquirer": "^8.2.6",
    "openai": "^4.24.1"
  }
}
