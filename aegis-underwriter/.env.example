# ===========================================
# AEGIS UNDERWRITER - Environment Configuration
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# BLOCKCHAIN CONFIGURATION
# ===========================================

# Agent's private key (WITH 0x prefix) - This wallet will hold the treasury
AGENT_PRIVATE_KEY="0x_your_private_key_here"

# Primary RPC URL (Polygon Amoy recommended)
RPC_URL="https://rpc-amoy.polygon.technology"

# Base Sepolia RPC (alternative testnet)
BASE_SEPOLIA_RPC="https://sepolia.base.org"

# ===========================================
# SMART CONTRACT ADDRESSES
# ===========================================

# Mock USDT token address on your chosen testnet
MOCK_USDT_ADDRESS="0x_deployed_mock_usdt_address"

# AegisLedger contract address (populated after deployment)
LEDGER_CONTRACT_ADDRESS="0x_deployed_ledger_address"

# ===========================================
# API KEYS
# ===========================================

# OpenAI API Key for LLM Brain
OPENAI_API_KEY="sk-..."

# Block explorer API keys (for contract verification)
ETHERSCAN_API_KEY=""
POLYGONSCAN_API_KEY=""

# ===========================================
# AGENT CONFIGURATION
# ===========================================

# Maximum loan amount in USDT
MAX_LOAN_AMOUNT=500

# Heartbeat interval in milliseconds (default: 5 minutes)
HEARTBEAT_INTERVAL_MS=300000
