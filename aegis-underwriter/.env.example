# Environment Variables Template
# Copy this file to .env and fill in your actual values

# ============================================
# BLOCKCHAIN CONFIGURATION
# ============================================

# Your agent wallet private key (starts with 0x)
# ⚠️ NEVER commit the actual .env file to GitHub!
AGENT_PRIVATE_KEY=0x_your_private_key_here

# RPC endpoint for Polygon Amoy testnet
RPC_URL=https://rpc-amoy.polygon.technology

# ============================================
# SMART CONTRACT ADDRESSES
# ============================================

# MockUSDT Token Contract (Already deployed on Polygon Amoy)
MOCK_USDT_ADDRESS=0x1f284415bA39067cFC39545c3bcfae1730BEB326

# AegisLedger Contract (Already deployed on Polygon Amoy)
LEDGER_CONTRACT_ADDRESS=0x9274Dc7Bc8fd3B49f0cc3CaE1340fFf65D5f5655

# ============================================
# AI CONFIGURATION
# ============================================

# Google Gemini API Key
# Get free key at: https://ai.google.dev/
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# BLOCKCHAIN ORACLE CONFIGURATION
# ============================================

# OKLink API Key for on-chain data
# Get free key at: https://www.oklink.com/
OKLINK_API_KEY=your_oklink_api_key_here

# ============================================
# LOAN SETTINGS
# ============================================

# Maximum loan amount in USDT
MAX_LOAN_AMOUNT=500

# ============================================
# ENVIRONMENT
# ============================================

NODE_ENV=development
